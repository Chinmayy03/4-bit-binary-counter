const int buttonPin = 2;
const int ledPins[4] = {3, 4, 5, 6};

int counter = 0;
bool lastState = HIGH;

// Non-blocking debounce variables
unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 50; // 50ms is standard for buttons

void updateLEDs(int val) {
  for (int i = 0; i < 4; i++) {
    // Bit-shift to check each bit (0-3) of the counter
    digitalWrite(ledPins[i], (val >> i) & 1);
  }
}

void setup() {
  pinMode(buttonPin, INPUT_PULLUP);

  for (int i = 0; i < 4; i++) {
    pinMode(ledPins[i], OUTPUT);
  }
  
  // Show initial state (0000) immediately
  updateLEDs(counter);
}

void loop() {
  bool reading = digitalRead(buttonPin);

  // Check if the button state changed (due to noise or press)
  if (reading != lastState) {
    lastDebounceTime = millis();
  }

  // Only act if the state has been stable for longer than the debounce delay
  if ((millis() - lastDebounceTime) > debounceDelay) {
    // If the button was just pressed (Falling edge for INPUT_PULLUP)
    // We use a static variable to track the "confirmed" state
    static bool confirmedState = HIGH;
    
    if (reading != confirmedState) {
      confirmedState = reading;

      // Increment only when the button is pressed (LOW)
      if (confirmedState == LOW) {
        counter = (counter + 1) & 0x0F; // Keep it 0-15
        updateLEDs(counter);
      }
    }
  }

  lastState = reading;
}
